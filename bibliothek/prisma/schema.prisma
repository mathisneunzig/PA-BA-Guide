generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
  GUEST
}

model User {
  id        String  @id @default(cuid())
  firstname String?
  lastname  String?
  username  String  @unique
  email     String  @unique
  phone     String?
  password  String

  // Billing address
  street  String?
  housenr String?
  zipcode String?
  city    String?
  country String?

  // Delivery address
  del_street  String?
  del_housenr String?
  del_zipcode String?
  del_city    String?
  del_country String?

  role Role @default(GUEST)

  // Email verification
  email_verified       Boolean   @default(false)
  email_verify_token   String?   @unique
  email_verify_expires DateTime?

  // Password reset
  reset_token         String?   @unique
  reset_token_expires DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cartHolds  CartHold[]
  feedbacks  Feedback[]
  loanGroups LoanGroup[]

  @@map("users")
}

enum LoanStatus {
  RESERVED
  ACTIVE
  RETURNED
  OVERDUE
  CANCELLED
}

enum HandoverMethod {
  PICKUP       // Abholung durch den Nutzer
  MEETINGPOINT // Treffpunkt vereinbaren
  SHIPPING     // Zusenden (mit Versandkosten)
}

model Book {
  id                  String  @id        // EAN-13 barcode (e.g. "0201234567897")
  title               String
  author              String
  isbn13              String?            // standard ISBN if different from barcode
  publisher           String?
  year                Int?
  description         String? @db.Text
  coverUrl            String?
  tags                String? // comma-separated Themengebiete, e.g. "Informatik,Datenbanken"
  programmiersprachen String? // comma-separated, e.g. "Python,Java"
  hauptkategorie      String? // e.g. "SAP", "KI", "SWA"
  regalnummer         String? // e.g. "SAP0001"
  language            String? @default("de")
  totalCopies         Int     @default(1)
  availableCopies     Int     @default(1)
  loanDurationWeeks   Int     @default(13) // per-book default, max 13

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cartHolds  CartHold[]
  loanItems  LoanItem[]

  @@map("books")
}

/// Temporary hold placed when a user adds a book to their cart.
/// Expires after 10 minutes; cleaned up on checkout or explicit removal.
model CartHold {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([bookId])
  @@index([expiresAt])
  @@map("cart_holds")
}

/// A loan group represents a single checkout event containing one or more books.
/// Shared metadata (dates, handover) lives here; per-book status lives in LoanItem.
model LoanGroup {
  id               String          @id @default(cuid())
  userId           String
  /// Aggregate status: RESERVED until activated, ACTIVE while any item is active,
  /// RETURNED when all items returned, CANCELLED when all items cancelled.
  status           LoanStatus      @default(RESERVED)
  startDate        DateTime
  dueDate          DateTime
  loanDurationDays Int
  notes            String?         @db.Text

  handoverMethod   HandoverMethod?
  handoverDate     DateTime?
  handoverLocation String?
  handoverCost     Decimal?        @db.Decimal(8, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items LoanItem[]

  @@index([userId])
  @@index([status])
  @@map("loan_groups")
}

/// One book within a LoanGroup. Tracks individual return/cancel status.
model LoanItem {
  id         String     @id @default(cuid())
  groupId    String
  bookId     String
  status     LoanStatus @default(RESERVED)
  returnedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group LoanGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  book  Book      @relation(fields: [bookId], references: [id], onDelete: Restrict)

  @@index([groupId])
  @@index([bookId])
  @@map("loan_items")
}

model Config {
  key   String @id
  value String

  @@map("config")
}

enum FeedbackCategory {
  BUG
  IMPROVEMENT
  QUESTION
  OTHER
}

enum FeedbackSeverity {
  LOW
  MEDIUM
  HIGH
}

enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

/// User-submitted feedback or issue report.
/// userId is nullable — unauthenticated users can also submit.
model Feedback {
  id          String           @id @default(cuid())
  userId      String?
  category    FeedbackCategory @default(OTHER)
  severity    FeedbackSeverity @default(LOW)
  description String           @db.Text
  pageUrl     String?
  status      FeedbackStatus   @default(OPEN)
  adminNote   String?          @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
  @@map("feedbacks")
}
