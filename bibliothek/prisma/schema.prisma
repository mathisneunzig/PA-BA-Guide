generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
  GUEST
}

model User {
  id        String  @id @default(cuid())
  firstname String?
  lastname  String?
  username  String  @unique
  email     String  @unique
  phone     String?
  password  String

  // Billing address
  street  String?
  housenr String?
  zipcode String?
  city    String?
  country String?

  // Delivery address
  del_street  String?
  del_housenr String?
  del_zipcode String?
  del_city    String?
  del_country String?

  role Role @default(GUEST)

  // Email verification
  email_verified       Boolean   @default(false)
  email_verify_token   String?   @unique
  email_verify_expires DateTime?

  // Password reset
  reset_token         String?   @unique
  reset_token_expires DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  loans     Loan[]
  cartHolds CartHold[]

  @@map("users")
}

enum LoanStatus {
  RESERVED
  ACTIVE
  RETURNED
  OVERDUE
  CANCELLED
}

enum HandoverMethod {
  PICKUP       // Abholung durch den Nutzer
  MEETINGPOINT // Treffpunkt vereinbaren
  SHIPPING     // Zusendet (mit Versandkosten)
  DROPOFF      // Nutzer bringt Buch selbst vorbei
}

model Book {
  id                  String  @id        // EAN-13 barcode (e.g. "0201234567897")
  title               String
  author              String
  isbn13              String?            // standard ISBN if different from barcode
  publisher           String?
  year                Int?
  description         String? @db.Text
  coverUrl            String?
  tags                String? // comma-separated Themengebiete, e.g. "Informatik,Datenbanken"
  programmiersprachen String? // comma-separated, e.g. "Python,Java"
  hauptkategorie      String? // e.g. "SAP", "KI", "SWA"
  regalnummer         String? // e.g. "SAP0001"
  language            String? @default("de")
  totalCopies         Int     @default(1)
  availableCopies     Int     @default(1)
  loanDurationWeeks   Int     @default(13) // per-book default, max 13

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  loans     Loan[]
  cartHolds CartHold[]

  @@map("books")
}

/// Temporary hold placed when a user adds a book to their cart.
/// Expires after 10 minutes; cleaned up on checkout or explicit removal.
model CartHold {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([bookId])
  @@index([expiresAt])
  @@map("cart_holds")
}

model Loan {
  id               String     @id @default(cuid())
  userId           String
  bookId           String
  status           LoanStatus @default(RESERVED)
  startDate        DateTime
  dueDate          DateTime
  returnedAt       DateTime?
  loanDurationDays Int
  notes            String?    @db.Text

  // Handover / pickup details
  handoverMethod   HandoverMethod?
  handoverDate     DateTime?        // PICKUP / MEETINGPOINT / DROPOFF
  handoverLocation String?          // MEETINGPOINT: where to meet
  handoverCost     Decimal?  @db.Decimal(8, 2) // SHIPPING: shipping cost in €

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Restrict)

  @@map("loans")
}

model Config {
  key   String @id
  value String

  @@map("config")
}
